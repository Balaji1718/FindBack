<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="8dp"
    android:foreground="?attr/selectableItemBackground"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Image Container -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="180dp">

            <ImageView
                android:id="@+id/imageItem"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@android:drawable/ic_menu_gallery"
                android:background="#F5F5F5"/>

            <!-- Status Badge overlay on image top-right -->
            <TextView
                android:id="@+id/statusBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:layout_margin="12dp"
                android:background="#4CAF50"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="OPEN"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:elevation="4dp" />
        </FrameLayout>

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp">

            <!-- Title -->
            <TextView
                android:id="@+id/textTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_toStartOf="@+id/btnReport"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="Item Title"
                android:textColor="#212121"
                android:textSize="18sp"
                android:textStyle="bold" />

            <!-- Report Button -->
            <ImageButton
                android:id="@+id/btnReport"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="false"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="4dp"
                android:scaleType="fitCenter"
                android:src="@android:drawable/ic_menu_report_image"
                app:tint="#757575" />

            <!-- Admin Menu (Hidden by default) -->
            <ImageButton
                android:id="@+id/adminMenuBtn"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_alignParentEnd="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="4dp"
                android:src="@android:drawable/ic_menu_more"
                android:visibility="gone" />

            <!-- Type (Lost/Found) -->
            <TextView
                android:id="@+id/textType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/textTitle"
                android:layout_marginTop="4dp"
                android:text="LOST"
                android:textColor="#F44336"
                android:textSize="13sp"
                android:textStyle="bold" />

            <!-- Posted By -->
            <TextView
                android:id="@+id/textPostedBy"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/textType"
                android:layout_marginTop="8dp"
                android:text="Posted by: Balaji"
                android:textColor="#616161"
                android:textSize="13sp" />

            <!-- Time -->
            <TextView
                android:id="@+id/textTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/textPostedBy"
                android:layout_marginTop="2dp"
                android:text="2 hours ago"
                android:textColor="#9E9E9E"
                android:textSize="11sp" />

        </RelativeLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>